---
import Logo from "../components/logo.astro";

const socials = [
	{ name: "Email", url: "mailto:angello3711@outlook.com" },
	{ name: "LinkedIn", url: "https://www.linkedin.com/in/angel-ontiveros-0b3679336/" },
	{ name: "GitHub", url: "https://github.com/AngellOntiveros" },
	{ name: "WhatsApp", url: "https://wa.me/573224148208" },
];
---

<section
  class="text-gray-700 bg-white border-t sm:mt-20 dark:bg-neutral-950 border-neutral-200 dark:border-neutral-800"
>
  <div
    class="container flex flex-col items-center py-8 mx-auto px-7 max-w-7xl sm:flex-row"
  >
    <Logo />
    <p
      class="mt-4 text-sm text-neutral-700 dark:text-neutral-100 sm:ml-4 sm:pl-4 sm:border-l sm:border-neutral-300 dark:sm:border-neutral-700 sm:mt-0"
    >
      © {new Date().getFullYear()} Ing. Angel Ontiveros
    </p>
    <span
      class="inline-flex flex-wrap justify-center gap-x-4 gap-y-2 mt-4 sm:ml-auto sm:mt-0 sm:justify-start"
    >
      {
        socials.map((social) => (
          <a
            href={social.url}
            target={social.url.startsWith("http") ? "_blank" : undefined}
            rel={social.url.startsWith("http") ? "noreferrer" : undefined}
            class="text-sm font-medium text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white"
          >
            {social.name}
          </a>
        ))
      }
    </span>
  </div>
</section>
