---
type StackSection = {
	category: string;
	items: string[];
};

interface Props {
	title: string;
	description?: string;
	sections: StackSection[];
}

const { title, description, sections } = Astro.props as Props;
---

<section class="mt-10">
  <h2 class="mb-2 text-2xl font-bold dark:text-neutral-200">{title}</h2>
  {
    description && (
      <p class="mb-5 text-sm leading-6 text-gray-600 dark:text-neutral-400 sm:text-base">
        {description}
      </p>
    )
  }
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {
      sections.map((section) => (
        <div class="p-4 border border-dashed rounded-lg border-neutral-300 dark:border-neutral-700">
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-neutral-700 dark:text-neutral-300">
            {section.category}
          </h3>
          <div class="flex flex-wrap gap-2">
            {section.items.map((item) => (
              <span class="inline-flex items-center rounded-full border border-neutral-300 px-2.5 py-1 text-xs font-medium text-neutral-700 dark:border-neutral-700 dark:text-neutral-300">
                {item}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
